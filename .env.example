# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/choreboard

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Session
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_COOKIE_NAME=cb_session
SESSION_TTL_DAYS=30

# Idle window (in minutes) for an "elevated" parent session on a shared
# family device — e.g. the kitchen tablet, where a kid is signed in and a
# parent walks up to approve a chore. After this many idle minutes the
# elevation auto-expires and the device falls back to the kid session.
PARENT_TABLET_IDLE_MIN=30

# Lifespan (in minutes) of a 6-digit device-pairing code. Single-use,
# regenerable from AdminFamily → Paired devices.
PAIRING_CODE_TTL_MIN=10

# Lifespan (in days) of a co-parent invite link. Was previously hardcoded
# in routes/family.ts; centralised here so all "thing expires after X"
# numbers live in one place.
INVITE_TTL_DAYS=7

# Belt-and-braces fallback for environments without a pre-deploy hook.
# When 'true', the API runs the Drizzle migrator once on process boot.
# Leave OFF on Render — render.yaml's `preDeployCommand` already runs
# `npm run db:migrate:prod` after a successful build, before the new
# instance is rotated into traffic. Drizzle's migrator is idempotent so
# enabling both is safe, just slightly slower on cold-start.
RUN_MIGRATIONS_ON_BOOT=false

# CORS — comma-separated list of allowed Origins.
# Dev: the Vite dev server.
# Prod: the SPA host, the marketing site (waitlist posts cross-origin),
# and the Capacitor schemes used by the iOS/Android shells.
WEB_ORIGIN=http://localhost:5173,https://app.choreboard.io,https://choreboard.io,capacitor://localhost,https://localhost

# Cookie domain — set to .choreboard.io in prod so a session cookie issued
# on app.choreboard.io is also sent to api.choreboard.io. Leave unset in dev.
# COOKIE_DOMAIN=.choreboard.io
APP_URL=http://localhost:5173

# Optional: serve the built SPA from this directory in production.
# When set, Fastify serves the SPA at / (so app.choreboard.io and
# api.choreboard.io can both be CNAMEs to the same Render service).
# WEB_DIST_DIR=../ChoreBoard-Web/dist

# --- Push (v1.x) ---
# Web Push (browser subscriptions)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:support@choreboard.io
#
# Apple Push Notification service (iOS native)
# APNS_TEAM_ID=
# APNS_KEY_ID=
# APNS_BUNDLE_ID=io.choreboard.app
# APNS_KEY_P8=          # contents of AuthKey_XXXX.p8 (newlines as \n)
# APNS_PRODUCTION=false
#
# Firebase Cloud Messaging (Android native)
# FCM_SERVICE_ACCOUNT_JSON=   # the full service-account JSON, single line

# --- Pricing ---
# Headline subscription price for the Family plan. Cents + ISO 4217 currency.
# Surfaced via GET /api/billing/quote so the SPA never hardcodes a number.
# Locked by Marketing before App Store / Play Console submission.
PRICING_HEADLINE_CENTS=599
PRICING_CURRENCY=AUD

# --- Billing (v1.x) ---
# Stripe (web subscriptions)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_FAMILY=
#
# Apple StoreKit (iOS IAP)
# APPLE_SHARED_SECRET=
# APPLE_BUNDLE_ID=io.choreboard.app
# APPLE_NOTIFICATIONS_AUDIENCE=production   # or 'sandbox'
#
# Google Play Billing (Android IAP)
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
# GOOGLE_PLAY_PACKAGE_NAME=io.choreboard.app
