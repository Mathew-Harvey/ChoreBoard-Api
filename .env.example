# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/choreboard

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Session
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_COOKIE_NAME=cb_session
SESSION_TTL_DAYS=30

# CORS — the web client origin during dev (Vite default)
WEB_ORIGIN=http://localhost:5173

# Optional: serve the built SPA from this directory in production
# WEB_DIST_DIR=../ChoreBoard-Web/dist
