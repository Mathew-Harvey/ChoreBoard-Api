# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/choreboard

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Session
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_COOKIE_NAME=cb_session
SESSION_TTL_DAYS=30

# CORS — comma-separated list of allowed Origins.
# Dev: the Vite dev server.
# Prod: the SPA host, the marketing site (waitlist posts cross-origin),
# and the Capacitor schemes used by the iOS/Android shells.
WEB_ORIGIN=http://localhost:5173,https://app.choreboard.io,https://choreboard.io,capacitor://localhost,https://localhost

# Cookie domain — set to .choreboard.io in prod so a session cookie issued
# on app.choreboard.io is also sent to api.choreboard.io. Leave unset in dev.
# COOKIE_DOMAIN=.choreboard.io
APP_URL=http://localhost:5173

# Optional: serve the built SPA from this directory in production.
# When set, Fastify serves the SPA at / (so app.choreboard.io and
# api.choreboard.io can both be CNAMEs to the same Render service).
# WEB_DIST_DIR=../ChoreBoard-Web/dist

# --- Push (v1.x) ---
# Web Push (browser subscriptions)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:support@choreboard.io
#
# Apple Push Notification service (iOS native)
# APNS_TEAM_ID=
# APNS_KEY_ID=
# APNS_BUNDLE_ID=io.choreboard.app
# APNS_KEY_P8=          # contents of AuthKey_XXXX.p8 (newlines as \n)
# APNS_PRODUCTION=false
#
# Firebase Cloud Messaging (Android native)
# FCM_SERVICE_ACCOUNT_JSON=   # the full service-account JSON, single line

# --- Supermarket integration (Calendar Canvas → shopping lists) ---
# RapidAPI key for the Woolworths Products API. Required for live price /
# image enrichment in shopping lists. When unset, the app degrades to plain
# text items (and serves whatever it has cached in `product_cache`).
# RAPIDAPI_WOOLWORTHS_KEY=

# --- Billing (v1.x) ---
# Stripe (web subscriptions)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_FAMILY=
#
# Apple StoreKit (iOS IAP)
# APPLE_SHARED_SECRET=
# APPLE_BUNDLE_ID=io.choreboard.app
# APPLE_NOTIFICATIONS_AUDIENCE=production   # or 'sandbox'
#
# Google Play Billing (Android IAP)
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
# GOOGLE_PLAY_PACKAGE_NAME=io.choreboard.app
