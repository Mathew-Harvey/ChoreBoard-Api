{
  "name": "choreboard-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ChoreBoard backend — Fastify + Drizzle + Postgres",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "argon2": "^0.40.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.32.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "nanoid": "^5.0.7",
    "pg": "^8.12.0",
    "stripe": "^22.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.23.0",
    "pino-pretty": "^11.2.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
